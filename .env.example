# App
APP_ENV=dev
APP_PORT=8000
LOG_LEVEL=INFO

# LLM / Embeddings
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_EMBEDDING_MODEL=

# Optional alternate providers
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Vector DB (Qdrant)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=travel_policy_chunks

# Keyword Search (OpenSearch)
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=
OPENSEARCH_INDEX=travel-policy-docs

# Storage
DATA_DIR=./data
RAW_DOCS_DIR=./data/raw
NORMALIZED_DOCS_DIR=./data/normalized

# Labeling backend (jsonl | sqlite | postgres)
LABELING_STORAGE_BACKEND=sqlite
LABELING_DB_PATH=./data/labeling.db
# For postgres backend:
# LABELING_STORAGE_BACKEND=postgres
# LABELING_POSTGRES_DSN=postgresql://user:password@host:5432/dbname
